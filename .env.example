# ---------------------------------------------------------------------------
# GenLayer AI Content Moderation — environment configuration
# Copy this file to .env and fill in the values. NEVER commit a real .env.
# ---------------------------------------------------------------------------

# Private key of the account used to deploy the contract and to sign integration
# tests / CLI calls. Used by gltest.config.yaml and deploy scripts.
# Fund it on Bradbury via https://testnet-faucet.genlayer.foundation
GENLAYER_PRIVATE_KEY="your-private-key-hex-without-0x-or-with-0x"

# ---- Frontend (Vite) — only VITE_* vars are exposed to the browser ----------

# Target network. One of: testnet-bradbury | testnet-asimov | studionet | localnet
VITE_GENLAYER_NETWORK="testnet-bradbury"

# Address of the deployed ContentModeration contract (set this after deploying).
VITE_GENLAYER_CONTRACT_ADDRESS=""

# Optional: override the RPC endpoint. Leave empty to use the chain default.
#   testnet-bradbury default: https://rpc-bradbury.genlayer.com
VITE_GENLAYER_RPC_URL=""

# Optional: a dev account private key for the frontend to sign write txs.
# If omitted, an ephemeral account is created (reads work; writes need funds).
VITE_GENLAYER_ACCOUNT_PRIVATE_KEY=""
